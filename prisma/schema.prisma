generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// === Better Auth Core Tables ===

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          String    @default("user")
  banned        Boolean   @default(false)
  banReason     String?
  banExpires    DateTime?

  // Additional fields for RentHub
  bio           String    @default("")
  location      String    @default("")
  averageRating Float     @default(0)
  reviewCount   Int       @default(0)
  isSuspended   Boolean   @default(false)
  idVerified    Boolean   @default(false)

  sessions Session[]
  accounts Account[]
  listings Listing[]
  favorites Favorite[]

  // Phase 3: Rental lifecycle relations
  rentalsAsRenter  Rental[]        @relation("RentalsAsRenter")
  rentalsAsOwner   Rental[]        @relation("RentalsAsOwner")
  conversationsAs1 Conversation[]  @relation("ConversationsAsUser1")
  conversationsAs2 Conversation[]  @relation("ConversationsAsUser2")
  messages         Message[]
  reviewsGiven     Review[]        @relation("ReviewsGiven")
  reviewsReceived  Review[]        @relation("ReviewsReceived")

  // Phase 9: Notifications
  emailNotifications    Boolean        @default(true)
  notificationsReceived Notification[] @relation("NotificationsReceived")
  notificationsActed    Notification[] @relation("NotificationsActed")
}

model Session {
  id             String   @id
  token          String   @unique
  userId         String
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  impersonatedBy String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id           String    @id
  userId       String
  accountId    String
  providerId   String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  password     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// === RentHub Domain Tables ===

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  icon        String
  description String   @default("")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  listings Listing[]
}

model Listing {
  id               String    @id @default(cuid())
  title            String
  description      String
  condition        String    @default("good") // new, like_new, good, fair, poor
  priceHourly      Float?
  priceDaily       Float?
  priceWeekly      Float?
  priceMonthly     Float?
  location         String    @default("")
  region           String    @default("")
  latitude         Float?
  longitude        Float?
  status           String    @default("active") // active, under_review, hidden, draft, rejected, unavailable
  aiVerified       Boolean   @default(false)
  moderationResult String?   // JSON string
  tags             String    @default("") // comma-separated
  ownerId          String
  categoryId       String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  owner    User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  category Category       @relation(fields: [categoryId], references: [id])
  images   ListingImage[]

  favorites Favorite[]

  // Phase 3: Rental lifecycle relations
  rentals       Rental[]
  conversations Conversation[]

  // Phase 7: AI translation cache
  translations ListingTranslation[]
}

model ListingTranslation {
  id                    String   @id @default(cuid())
  listingId             String
  locale                String
  translatedTitle       String
  translatedDescription String
  detectedLanguage      String   @default("")
  createdAt             DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, locale])
}

model ListingImage {
  id        String  @id @default(cuid())
  url       String
  isCover   Boolean @default(false)
  sortOrder Int     @default(0)
  listingId String

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

// === Phase 3: Rental Lifecycle Tables ===

model Rental {
  id              String   @id @default(cuid())
  startDate       DateTime
  endDate         DateTime
  status          String   @default("requested") // requested, approved, active, returned, completed, declined
  message         String   @default("")
  securityDeposit Float    @default(0)
  totalPrice      Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  listingId String
  renterId  String
  ownerId   String

  listing      Listing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  renter       User           @relation("RentalsAsRenter", fields: [renterId], references: [id], onDelete: Cascade)
  owner        User           @relation("RentalsAsOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  reviews      Review[]
  conversation Conversation?
  events       RentalEvent[]
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listingId String
  rentalId  String?  @unique
  user1Id   String
  user2Id   String

  listing  Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  rental   Rental?   @relation(fields: [rentalId], references: [id], onDelete: SetNull)
  user1    User      @relation("ConversationsAsUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2    User      @relation("ConversationsAsUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([listingId, user1Id, user2Id])
}

model Message {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  read      Boolean  @default(false)

  senderId       String
  conversationId String

  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String   @default("")
  createdAt DateTime @default(now())

  rentalId   String
  reviewerId String
  revieweeId String

  rental   Rental @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  reviewer User   @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee User   @relation("ReviewsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)

  @@unique([rentalId, reviewerId])
}

// === Phase 8: Favorites & Timeline Tables ===

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
}

// === Phase 9: Notifications ===

model Notification {
  id          String   @id @default(cuid())
  recipientId String
  actorId     String
  type        String   // "rental" | "message" | "review" | "favorite"
  title       String
  message     String   @default("")
  linkUrl     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  recipient User @relation("NotificationsReceived", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User @relation("NotificationsActed", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([recipientId, read])
  @@index([recipientId, createdAt])
}

model RentalEvent {
  id        String   @id @default(cuid())
  rentalId  String
  status    String   // requested, approved, active, returned, completed, declined
  actorId   String   // who triggered the change
  createdAt DateTime @default(now())

  rental Rental @relation(fields: [rentalId], references: [id], onDelete: Cascade)

  @@index([rentalId])
}
